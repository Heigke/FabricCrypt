# Copy to .env and edit. .env is gitignored.

# Override thermal thresholds (Celsius) for the per-chassis safety guard.
# Defaults assume a small laptop-class chassis (HP Z2 mini G1a, ~99C trip).
# A desktop with strong cooling can safely raise these (e.g. 85/80/65).
FABRICCRYPT_THERMAL_ABORT_C=68
FABRICCRYPT_THERMAL_PAUSE_C=63
FABRICCRYPT_THERMAL_COOL_C=50

# Optional: path to a peer's paired_sigs.npz for cross-chip training.
# FABRICCRYPT_PEER_NPZ=data/peer_paired_sigs.npz
